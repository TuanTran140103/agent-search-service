# App
DEBUG=false
PORT=8000
WEB_CONCURRENCY=4

# ── Primary LLM ────────────────────────────────────────────────────
LLM_PROVIDER=openai              # openai | anthropic | google_genai | nvidia
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here     # falls back to OPENAI_API_KEY
LLM_BASE_URL=                    # For custom endpoints / gateways
LLM_TEMPERATURE=0.7

# ── Per-provider keys / base URLs (optional overrides) ─────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GOOGLE_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=

# ── DeepAgents ─────────────────────────────────────────────────────
DEEPAGENT_MEMORY_ENABLED=false
DEEPAGENT_MEMORY_PATHS=["/memories/user_preferences.md"]
# Comma-separated tool names requiring human approval:
DEEPAGENT_INTERRUPT_ON=

# ── LangSmith (optional) ───────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lm-agent-service
LANGSMITH_TRACING=false

# ── PostgreSQL (checkpointer) ──────────────────────────────────────
DATABASE_URI=postgresql://chatbox:chatbox-engine123456@localhost:5432/lm_agent

# ── Redis (required for queue + rate limiter + worker) ─────────────
REDIS_URI=redis://localhost:6379/0

# ── Rate Limit ─────────────────────────────────────────────────────
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=1000

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false

# ── Search API (external .NET service) ─────────────────────────────
SEARCH_API_BASE_URL=http://localhost:5000/api/v1/search
SEARCH_API_TOKEN=
