# App
DEBUG=false
PORT=8000
WEB_CONCURRENCY=4

# LLM
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# LangSmith (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lm-agent-service
LANGSMITH_TRACING=false

# PostgreSQL
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/lm_agent

# Redis
REDIS_URI=redis://localhost:6379/0

# Queue (inprocess | redis)
QUEUE_BACKEND=inprocess

# Rate Limit
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=1000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Search API (external .NET service)
SEARCH_API_BASE_URL=http://localhost:5000/api/v1/search
SEARCH_API_TOKEN=
